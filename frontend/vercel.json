{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://sistema-mei.onrender.com/$1"
    },
    {
      "source": "/login/oauth2/(.*)",
      "destination": "https://sistema-mei.onrender.com/login/oauth2/$1"
    },
    {
      "source": "/oauth2/(.*)",
      "destination": "https://sistema-mei.onrender.com/oauth2/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
